# Salin file ini menjadi ".env" lalu isi dengan nilai dari proyek Supabase Anda.
# Supabase Dashboard → Project Settings → Data API / API Keys
#
# JANGAN commit file .env yang sudah berisi nilai asli (sudah diabaikan .gitignore).
# Untuk deploy (Cloudflare Pages / Netlify), isi nilai ini di menu Environment Variables.

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...isi_anon_public_key_di_sini
